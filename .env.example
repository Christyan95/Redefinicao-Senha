# Z-API (WhatsApp Gateway)
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# PostgreSQL (Auditoria e OTPs)
DB_USER=
DB_HOST=
DB_DATABASE=
DB_PASSWORD=
DB_PORT=5432
DB_SSL_REJECT_UNAUTHORIZED=true

# Oracle Database (ERP — Fonte de dados de colaboradores)
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECTION_STRING=host:port/service_name
ORACLE_CONFIG_DIR=C:\instantclient_23_7

# Active Directory (ADSI via PowerShell)
# Formato: LDAP://IP_DO_DC/DC=dominio,DC=com,DC=br
AD_LDAP_PATH=
AD_USER=
AD_PASSWORD=
